# Copy this file to .env and add your keys.
# The UI intentionally does not expose model/provider choices.

# Gemini is used first.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Groq is used as fallback if Gemini fails or no Gemini key is available.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: tweak output creativity.
LLM_TEMPERATURE=0.2
