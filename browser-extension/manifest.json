{
  "manifest_version": 3,
  "name": "BidForge AI Autocomplete Helper",
  "version": "1.0.0",
  "description": "Auto-fill client questionnaires and procurement portals using BidForge AI local agent database.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
